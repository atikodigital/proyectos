# ── Servidor ─────────────────────────────────────────────────
PORT=3000

# ── Proveedor de IA ──────────────────────────────────────────
AGENT_PROVIDER=openai
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Voz (TTS / Realtime) ─────────────────────────────────────
AGENT_TTS_MODEL=gpt-4o-mini-tts
AGENT_TTS_VOICE=onyx
AGENT_TTS_INSTRUCTIONS=
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=ballad

# ── WhatsApp Business (Meta) ─────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=atiko_2026_secret

# ── Redes sociales (Publicador Meta) ─────────────────────────
# App de Meta (la MISMA que WhatsApp). developers.facebook.com
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://agent.atikodigital.cl/api/social/callback/meta
# Postgres atiko-db (si falta, el token store usa memoria — solo dev)
DATABASE_URL=
# Secreto para firmar el `state` del OAuth (anti-CSRF). Si falta, reusa META_APP_SECRET.
SOCIAL_STATE_SECRET=
